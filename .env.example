# Copy this to .env.local and fill in the values
# Do NOT commit .env.local to GitHub

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Google OAuth
# Create at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
# For prod: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Upstash Redis (via Vercel Marketplace or upstash.com — free tier)
# Add the Upstash Redis integration from Vercel dashboard → Integrations
# It auto-fills these:
KV_REST_API_URL=
KV_REST_API_TOKEN=
